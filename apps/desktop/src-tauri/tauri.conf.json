{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "denoize",
  "version": "0.5.0",
  "identifier": "io.github.penguin425.denoize",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "denoize",
        "width": 1240,
        "height": 820,
        "minWidth": 920,
        "minHeight": 660,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost; media-src 'self' asset: http://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$TEMP/denoize-previews/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.png"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY1QUUwMkU3NTkzQzY0RDkKUldUWlpEeFo1d0t1OVFjQUJXRTJTeTdaRWc2eFFoUVcrdlZWY2x5cGdFdThRbmpibk5iWm1RdmkK",
      "endpoints": [
        "https://github.com/penguin425/denoize/releases/latest/download/latest.json"
      ],
      "windows": { "installMode": "passive" }
    }
  }
}
